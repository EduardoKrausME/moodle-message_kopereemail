{{!
    @template message_kopereemail/admin_providers

    Example context (json):
    {
        "hasproviders": true,
        "providers": [
            {
                "providername": "Course completed",
                "component": "core",
                "name": "coursecompleted",
                "hascustomtemplate": true,
                "editurl": "#",
                "deleteurl": "#",
                "previewurl": "#"
            }
        ]
    }
}}

<div class="message-kopereemail-admin-providers">
    <p>{{#str}}settings_customtemplates_desc, message_kopereemail{{/str}}</p>

    {{#hasproviders}}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                <tr>
                    <th>{{#str}}table_provider, message_kopereemail{{/str}}</th>
                    <th>{{#str}}table_component, message_kopereemail{{/str}}</th>
                    <th>{{#str}}table_name, message_kopereemail{{/str}}</th>
                    <th>{{#str}}table_actions, message_kopereemail{{/str}}</th>
                </tr>
                </thead>
                <tbody>
                {{#providers}}
                    <tr>
                        <td>{{providername}}</td>
                        <td><code>{{component}}</code></td>
                        <td><code>{{name}}</code></td>
                        <td>
                            <div class="message-kopereemail-admin-providers__actions">
                                {{#hascustomtemplate}}
                                    <a href="{{editurl}}" class="btn btn-sm btn-info">
                                        {{#str}}action_edit, message_kopereemail{{/str}}
                                    </a>
                                    <a href="{{deleteurl}}" class="btn btn-sm btn-danger">
                                        {{#str}}action_delete, message_kopereemail{{/str}}
                                    </a>
                                    <a href="{{previewurl}}" class="btn btn-sm btn-success">
                                        {{#str}}action_preview_click, message_kopereemail{{/str}}
                                    </a>
                                {{/hascustomtemplate}}

                                {{^hascustomtemplate}}
                                    <a href="{{editurl}}" class="btn btn-sm btn-success">
                                        {{#str}}action_create, message_kopereemail{{/str}}
                                    </a>
                                {{/hascustomtemplate}}
                            </div>
                        </td>
                    </tr>
                {{/providers}}
                </tbody>
            </table>
        </div>
    {{/hasproviders}}

    {{^hasproviders}}
        <div class="alert alert-info mb-0">
            {{#str}}messages, message_kopereemail{{/str}}
        </div>
    {{/hasproviders}}
</div>
